#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
fi
# cmd-shim-target=/app/.pnpm-store/v11/links/@/pnpm/11.5.1/3f0663b57762c6a2988626a5497ae1c0191b5e8a7ecc4a7aef8d3d44442f8262/node_modules/pnpm/bin/pnpx.mjs
